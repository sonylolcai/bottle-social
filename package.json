{
  "name": "drift-bottle",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "agent": "pnpm --filter @drift-bottle/dev-agent exec node --experimental-strip-types src/cli.ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
